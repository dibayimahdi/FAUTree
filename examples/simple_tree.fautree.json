{
  "schemaVersion": "0.1.0",
  "project": {
    "id": "generic-fault-tree",
    "name": "Generic Fault Tree Project",
    "description": "Starter example for FAUTree.",
    "createdBy": "FAUTree"
  },
  "analysis": {
    "missionTime": 1000,
    "timeUnit": "hour",
    "variableOrdering": "topological"
  },
  "nodes": [
    {
      "id": "top",
      "type": "top_event",
      "label": "System failure"
    },
    {
      "id": "g1",
      "type": "gate",
      "gateType": "OR",
      "label": "Top event logic"
    },
    {
      "id": "e1",
      "type": "basic_event",
      "label": "Power supply failure",
      "failureRate": 0.000002
    },
    {
      "id": "g2",
      "type": "gate",
      "gateType": "AND",
      "label": "Protection subsystem failure"
    },
    {
      "id": "e2",
      "type": "basic_event",
      "label": "Primary protection failure",
      "failureRate": 0.0000015
    },
    {
      "id": "e3",
      "type": "basic_event",
      "label": "Backup protection failure",
      "failureRate": 0.0000015
    },
    {
      "id": "e4",
      "type": "basic_event",
      "label": "Control unit failure",
      "failureRate": 0.000003
    }
  ],
  "edges": [
    {
      "source": "top",
      "target": "g1"
    },
    {
      "source": "g1",
      "target": "e1"
    },
    {
      "source": "g1",
      "target": "g2"
    },
    {
      "source": "g1",
      "target": "e4"
    },
    {
      "source": "g2",
      "target": "e2"
    },
    {
      "source": "g2",
      "target": "e3"
    }
  ]
}
